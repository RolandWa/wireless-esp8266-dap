	(text "CONFIG_IDF_TARGET_ESP32C3\n  #define PIN_SWDIO _      // SPI MISO\n  #define PIN_SWDIO_MOSI 7 // SPI MOSI\n  #define PIN_SWCLK 6\n  #define PIN_TDO 8        // device TDO -> Host Data Input\n  #define PIN_TDI 9\n  #define PIN_nTRST 4       // optional\n  #define PIN_nRESET 5"
		(exclude_from_sim no)
		(at 17.78 30.48 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "0c42b6f9-d7c1-43e5-84bd-c0ecc8c8fa90")
	)
	(text "Max 5V min 1.25V 1.25A short protection\nVout = (1+ R3/R1) x 1.25V + 60uA x R3\n12k / 100k -> 1.4V\n12k / 20k -> 2.0 V\n12k / 12k -> 2.5V\n12k / 7.317k -> 3.3V\n12k / 4k -> 5V\n"
		(exclude_from_sim no)
		(at 45.72 154.94 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
